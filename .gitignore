# ============================================================
#  .gitignore — Lógica de Programação e Algoritmos
#  Curso Técnico em Desenvolvimento de Sistemas | SENAI
# ============================================================

# -------------------------------------------------------
# Node.js
# -------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.npm
.pnp
.pnp.js

# -------------------------------------------------------
# VisualG — Pseudocódigo (.alg / .ALG)
# -------------------------------------------------------
*.alg
*.ALG

# -------------------------------------------------------
# Flowgorithm — Fluxograma executável (.fprg)
# -------------------------------------------------------
*.fprg

# -------------------------------------------------------
# Draw.io — Fluxograma visual (.drawio)
# -------------------------------------------------------
*.drawio

# -------------------------------------------------------
# Microsoft Word e Office
# -------------------------------------------------------
*.doc
*.docx
*.xls
*.xlsx
*.ppt
*.pptx

# -------------------------------------------------------
# PDF
# -------------------------------------------------------
*.pdf

# -------------------------------------------------------
# Sistemas Operacionais
# -------------------------------------------------------

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# -------------------------------------------------------
# Editores e IDEs
# -------------------------------------------------------

# VS Code
.vscode/
*.code-workspace


# -------------------------------------------------------
# Logs e temporários
# -------------------------------------------------------
logs/
*.log
*.tmp
*.temp
*.bak
*.cache
dist/
build/
out/
